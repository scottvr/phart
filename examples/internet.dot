digraph G {
    rankdir=LR;
    node [shape=box, style=filled, fillcolor="#f9f9f9", fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9, color="#555555"];

    // Nodes
    User     [label="Browser User", fillcolor="#e1f5fe"];
    Gateway  [label="Gateway / Router"];
    ISP      [label="ISP / DNS Resolver"];
    Backbone [label="Internet Backbone", shape=cloud, fillcolor="#eceff1"];
    FW       [label="Firewall", fillcolor="#ffebee"];
    LB       [label="Load Balancer", fillcolor="#fff3e0"];
    WS1      [label="Web Server A", fillcolor="#e8f5e9"];
    WS2      [label="Web Server B", fillcolor="#e8f5e9"];

    // Connections with Edge Labels
    User     -> Gateway  [label="LAN / WiFi"];
    Gateway  -> ISP      [label="DNS Query (53)"];
    ISP      -> Backbone [label="Recursive Lookup"];
    Backbone -> FW       [label="HTTPS (443)"];
    FW       -> LB       [label="TCP Traffic"];
    LB       -> WS1      [label="Forwarding"];
    LB       -> WS2      [label="Forwarding"];

    // Keep servers aligned vertically
    subgraph test { label="cluster"; rank=same; WS1; WS2; }
}

// graph LR
//    User[Browser User] --> Gateway[Gateway / Router]
//    Gateway --> ISP[ISP / DNS Resolver]
//    ISP --> Backbone[Internet Backbone]
//    Backbone --> FW[Firewall]
//    FW --> LB[Load Balancer]
//    LB --> WS1[Web Server A]
//    LB --> WS2[Web Server B]
