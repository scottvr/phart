digraph {
rankdir = LR;
node [fontname="Helvetica"];
"config" [shape=none, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD COLSPAN="3"><B>config</B></TD></TR><TR><TD PORT="name_in">name</TD><TD ALIGN="left" SIDES="LTB"><I>text</I></TD><TD ALIGN="left" SIDES="RTB" PORT="name_out">❄️</TD></TR><TR><TD PORT="value_in">value</TD><TD ALIGN="left" SIDES="LTB"><I>text</I></TD><TD ALIGN="left" SIDES="RTB" PORT="value_out"></TD></TR></TABLE>>];
"fingerprint" [shape=none, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD COLSPAN="3"><B>fingerprint</B></TD></TR><TR><TD PORT="fpr_in">fpr</TD><TD ALIGN="left" SIDES="LTB"><I>blob</I></TD><TD ALIGN="left" SIDES="RTB" PORT="fpr_out">🔑❄️</TD></TR><TR><TD PORT="kid_in">kid</TD><TD ALIGN="left" SIDES="LTB"><I>blob</I></TD><TD ALIGN="left" SIDES="RTB" PORT="kid_out"></TD></TR><TR><TD PORT="keygrip_in">keygrip</TD><TD ALIGN="left" SIDES="LTB"><I>blob</I></TD><TD ALIGN="left" SIDES="RTB" PORT="keygrip_out"></TD></TR><TR><TD PORT="subkey_in">subkey</TD><TD ALIGN="left" SIDES="LTB"><I>integer</I></TD><TD ALIGN="left" SIDES="RTB" PORT="subkey_out"></TD></TR><TR><TD PORT="ubid_in">ubid</TD><TD ALIGN="left" SIDES="LTB"><I>blob</I></TD><TD ALIGN="left" SIDES="RTB" PORT="ubid_out"></TD></TR></TABLE>>];
"issuer" [shape=none, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD COLSPAN="3"><B>issuer</B></TD></TR><TR><TD PORT="sn_in">sn</TD><TD ALIGN="left" SIDES="LTB"><I>text</I></TD><TD ALIGN="left" SIDES="RTB" PORT="sn_out"></TD></TR><TR><TD PORT="dn_in">dn</TD><TD ALIGN="left" SIDES="LTB"><I>text</I></TD><TD ALIGN="left" SIDES="RTB" PORT="dn_out"></TD></TR><TR><TD PORT="ubid_in">ubid</TD><TD ALIGN="left" SIDES="LTB"><I>blob</I></TD><TD ALIGN="left" SIDES="RTB" PORT="ubid_out"></TD></TR></TABLE>>];
"pubkey" [shape=none, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD COLSPAN="3"><B>pubkey</B></TD></TR><TR><TD PORT="ubid_in">ubid</TD><TD ALIGN="left" SIDES="LTB"><I>blob</I></TD><TD ALIGN="left" SIDES="RTB" PORT="ubid_out">🔑❄️</TD></TR><TR><TD PORT="type_in">type</TD><TD ALIGN="left" SIDES="LTB"><I>integer</I></TD><TD ALIGN="left" SIDES="RTB" PORT="type_out"></TD></TR><TR><TD PORT="ephemeral_in">ephemeral</TD><TD ALIGN="left" SIDES="LTB"><I>integer</I></TD><TD ALIGN="left" SIDES="RTB" PORT="ephemeral_out"></TD></TR><TR><TD PORT="revoked_in">revoked</TD><TD ALIGN="left" SIDES="LTB"><I>integer</I></TD><TD ALIGN="left" SIDES="RTB" PORT="revoked_out"></TD></TR><TR><TD PORT="keyblob_in">keyblob</TD><TD ALIGN="left" SIDES="LTB"><I>blob</I></TD><TD ALIGN="left" SIDES="RTB" PORT="keyblob_out"></TD></TR></TABLE>>];
"userid" [shape=none, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD COLSPAN="3"><B>userid</B></TD></TR><TR><TD PORT="uid_in">uid</TD><TD ALIGN="left" SIDES="LTB"><I>text</I></TD><TD ALIGN="left" SIDES="RTB" PORT="uid_out"></TD></TR><TR><TD PORT="addrspec_in">addrspec</TD><TD ALIGN="left" SIDES="LTB"><I>text?</I></TD><TD ALIGN="left" SIDES="RTB" PORT="addrspec_out"></TD></TR><TR><TD PORT="type_in">type</TD><TD ALIGN="left" SIDES="LTB"><I>integer</I></TD><TD ALIGN="left" SIDES="RTB" PORT="type_out"></TD></TR><TR><TD PORT="uidno_in">uidno</TD><TD ALIGN="left" SIDES="LTB"><I>integer</I></TD><TD ALIGN="left" SIDES="RTB" PORT="uidno_out"></TD></TR><TR><TD PORT="ubid_in">ubid</TD><TD ALIGN="left" SIDES="LTB"><I>blob</I></TD><TD ALIGN="left" SIDES="RTB" PORT="ubid_out"></TD></TR></TABLE>>];

"fingerprint":"ubid_out":e -> "pubkey":"ubid_in":_;
"issuer":"ubid_out":e -> "pubkey":"ubid_in":_;
"userid":"ubid_out":e -> "pubkey":"ubid_in":_;
}
